# ============================================================================
# TrackIt Environment Variables Example
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------

# PostgreSQL Database Connection String
# Format: postgresql://username:password@host:port/database?options
# Required options: sslmode=require, pgbouncer=true (recommended)

DATABASE_URL="postgresql://doadmin:YOUR_PASSWORD_HERE@db-postgresql-sgp1-04384-do-user-16924107-0.f.db.ondigitalocean.com:25060/defaultdb?sslmode=require&pgbouncer=true"

# DigitalOcean PostgreSQL Connection Details
# - Host: db-postgresql-sgp1-04384-do-user-16924107-0.f.db.ondigitalocean.com
# - Port: 25060
# - Database: defaultdb
# - Username: doadmin
# - SSL Mode: require (mandatory for DigitalOcean)
# - Connection Pooling: Enable pgbouncer for better performance

# Optional: Override connection pool size
# Uncomment and adjust based on your needs
# DATABASE_URL="postgresql://doadmin:YOUR_PASSWORD_HERE@db-postgresql-sgp1-04384-do-user-16924107-0.f.db.ondigitalocean.com:25060/defaultdb?sslmode=require&pgbouncer=true&connection_limit=10"

# ----------------------------------------------------------------------------
# NextAuth.js Configuration
# ----------------------------------------------------------------------------

# The URL of your application (used for OAuth callbacks)
# For local development: http://localhost:3000
# For production: https://your-app.vercel.app

NEXTAUTH_URL="http://localhost:3000"

# Secret key for encrypting JWT tokens and session cookies
# Generate a secure random string with:
#   openssl rand -base64 32
# Must be at least 32 characters long

NEXTAUTH_SECRET="generate-a-secure-random-string-at-least-32-characters-long-using-openssl-rand-base64-32"

# Optional: NextAuth debug mode (only for development)
# NEXTAUTH_DEBUG="true"

# ----------------------------------------------------------------------------
# Application Environment
# ----------------------------------------------------------------------------

# Node environment: development, test, or production
# - development: Enables detailed logging and debugging
# - test: Optimized for testing
# - production: Optimized for performance and security

NODE_ENV="development"

# Optional: Application base path if deployed to subdirectory
# BASE_PATH="/subdirectory"

# ----------------------------------------------------------------------------
# OAuth Providers (Optional - for future implementation)
# ----------------------------------------------------------------------------

# Google OAuth
# NEXTAUTH_GOOGLE_CLIENT_ID="your-google-client-id"
# NEXTAUTH_GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# NEXTAUTH_GITHUB_CLIENT_ID="your-github-client-id"
# NEXTAUTH_GITHUB_CLIENT_SECRET="your-github-client-secret"

# Discord OAuth
# NEXTAUTH_DISCORD_CLIENT_ID="your-discord-client-id"
# NEXTAUTH_DISCORD_CLIENT_SECRET="your-discord-client-secret"

# ----------------------------------------------------------------------------
# External APIs (Optional - for future implementation)
# ----------------------------------------------------------------------------

# Example: AniList API for anime/manga data
# ANILIST_API_URL="https://graphql.anilist.co"

# Example: TMDB API for movies/TV shows data
# TMDB_API_KEY="your-tmdb-api-key"
# TMDB_API_URL="https://api.themoviedb.org/3"

# Example: Open Library API for books
# OPEN_LIBRARY_API_URL="https://openlibrary.org"

# Example: IGDB API for games
# IGDB_CLIENT_ID="your-igdb-client-id"
# IGDB_CLIENT_SECRET="your-igdb-client-secret"

# ----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# ----------------------------------------------------------------------------

# SMTP settings for sending emails
# EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
# EMAIL_FROM="TrackIt <noreply@trackit.com>"

# Resend (modern email service)
# RESEND_API_KEY="your-resend-api-key"
# RESEND_FROM="noreply@trackit.com"

# ----------------------------------------------------------------------------
# Analytics and Monitoring (Optional)
# ----------------------------------------------------------------------------

# Vercel Analytics (automatic on Vercel)
# VERCEL_ANALYTICS_ID="your-vercel-analytics-id"

# Google Analytics
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Sentry (error tracking)
# SENTRY_DSN="your-sentry-dsn"
# SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ----------------------------------------------------------------------------
# Feature Flags (Optional - enable/disable features)
# ----------------------------------------------------------------------------

# Enable/disable dark mode by default
# DEFAULT_DARK_MODE="true"

# Enable/disable user registration
# ALLOW_REGISTRATION="true"

# Maximum number of items per user
# MAX_ITEMS_PER_USER="1000"

# Enable/activity logging
# ENABLE_ACTIVITY_LOGGING="true"

# ----------------------------------------------------------------------------
# Performance Tuning (Optional)
# ----------------------------------------------------------------------------

# Page size for paginated lists
# PAGE_SIZE="20"

# Cache duration in seconds
# CACHE_DURATION="3600"

# Enable/disable image optimization
# ENABLE_IMAGE_OPTIMIZATION="true"

# ----------------------------------------------------------------------------
# Security (Optional)
# ----------------------------------------------------------------------------

# Allowed origins for CORS (comma-separated)
# ALLOWED_ORIGINS="http://localhost:3000,https://your-app.vercel.app"

# Rate limiting settings
# RATE_LIMIT_MAX="100"
# RATE_LIMIT_WINDOW="900000"  # 15 minutes in milliseconds

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
#
# 1. Never commit .env.local or .env files with real credentials
# 2. Generate strong, unique secrets for production
# 3. Keep your DATABASE_URL secure and never share it
# 4. Rotate secrets regularly in production
# 5. Use different DATABASE_URL for each environment (dev/staging/prod)
# 6. Test your configuration before deploying to production
#
# ============================================================================
